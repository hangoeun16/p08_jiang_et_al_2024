# Copy this file to .env and fill in your values.
# The .env file must NOT be committed to the repository.

# WRDS account username (required to pull Call Report data)
WRDS_USERNAME=jdoe

# Date range for WRDS data pull (must bracket REPORT_DATE)
START_DATE=2021-12-31
END_DATE=2023-09-30

# Balance sheet snapshot date (Q1 2022, matches Jiang et al. 2024)
REPORT_DATE=2022-03-31

# MTM loss measurement end date (Q1 2023, matches paper)
MTM_END_DATE=2023-03-31

# Optional: override default data and output directories
# DATA_DIR=_data
# OUTPUT_DIR=_output
# MANUAL_DATA_DIR=data_manual
